{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Dev",
      "program": "${workspaceFolder}/src/index.ts",
      "runtimeArgs": ["--require", "tsx/cjs"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "resolveSourceMapLocations": ["${workspaceFolder}/src/**"],
      "outputCapture": "std"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach (inspect)",
      "port": 9229,
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/src/**",
        "${workspaceFolder}/scripts/**"
      ]
    }
  ]
}
