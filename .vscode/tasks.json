{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "QB REPL",
      "type": "shell",
      "command": "set -a && source .env && set +a && node --require tsx/cjs --inspect scripts/repl.ts",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
