APP_PORT=8190
APP_ENV=development
GIT_SHA=local

# PostgreSQL — shared dev DB (vh-dev-db) or standalone
PGHOST=localhost
PGPORT=5435
PGUSER=user
PGPASSWORD=password
PGDATABASE=accounting
# Test DB defaults to ${PGDATABASE}_test (accounting_test). Override with PGDATABASE_TEST=
# PGDATABASE_TEST=accounting_test

# Keycloak — same client as orders service
KEYCLOAK_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# QuickBooks — from developer.intuit.com
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=sandbox
QB_REDIRECT_URI=http://localhost:8190/v1/quickbooks/auth/callback

# Sentry (optional in dev)
SENTRY_DSN=
